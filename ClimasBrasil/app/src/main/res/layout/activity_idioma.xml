<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#67B0D1"
    tools:context=".IdiomaActivity">

    <ImageView
        android:id="@+id/imgFR"
        android:layout_width="0dp"
        android:layout_height="130dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="10dp"
        android:onClick="idiomaFR"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/imgDE"
        app:layout_constraintTop_toBottomOf="@+id/imgEN"
        app:layout_constraintVertical_bias="0.0"
        app:srcCompat="@drawable/fr" />

    <ImageView
        android:id="@+id/imgIT"
        android:layout_width="0dp"
        android:layout_height="130dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="10dp"
        android:onClick="idiomaIT"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/imgDE"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imgEN"
        app:layout_constraintVertical_bias="0.0"
        app:srcCompat="@drawable/it" />

    <ImageView
        android:id="@+id/imgDE"
        android:layout_width="0dp"
        android:layout_height="130dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="10dp"
        android:onClick="idiomaDE"
        app:layout_constraintEnd_toStartOf="@+id/imgFR"
        app:layout_constraintStart_toEndOf="@+id/imgIT"
        app:layout_constraintTop_toBottomOf="@+id/imgEN"
        app:srcCompat="@drawable/de" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="10dp"
        android:text="@string/textoIdiona"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnVoltar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="110dp"
        android:backgroundTint="#8DC6DD"

        android:onClick="fechar"
        android:text="@string/btnVoltar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/imgPT"
        android:layout_width="0dp"
        android:layout_height="130dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="10dp"
        android:onClick="idiomaPT"
        app:layout_constraintEnd_toStartOf="@+id/imgEN"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView"
        app:srcCompat="@drawable/pt" />

    <ImageView
        android:id="@+id/imgEN"
        android:layout_width="0dp"
        android:layout_height="130dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:onClick="idiomaEN"
        app:layout_constraintEnd_toStartOf="@+id/imgES"
        app:layout_constraintStart_toEndOf="@+id/imgPT"
        app:layout_constraintTop_toTopOf="@+id/imgPT"
        app:srcCompat="@drawable/en" />

    <ImageView
        android:id="@+id/imgES"
        android:layout_width="0dp"
        android:layout_height="130dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:onClick="idiomaES"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/imgEN"
        app:layout_constraintTop_toTopOf="@+id/imgEN"
        app:srcCompat="@drawable/es" />

</androidx.constraintlayout.widget.ConstraintLayout>